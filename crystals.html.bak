            <!-- 产品10：多宝手串 -->
            <div class="crystal-card">
                <img class="crystal-img" src="https://picsum.photos/seed/multi-crystal/400/300" alt="多宝手串">
                <div class="crystal-info">
                    <div class="crystal-name">多宝手串</div>
                    <div class="crystal-desc">
                        7种天然水晶混搭，全方位能量加持。送礼首选，适合追求全能能量者。
                    </div>
                    <div class="crystal-tags">
                        <span class="crystal-tag">全能</span>
                        <span class="crystal-tag">送礼</span>
